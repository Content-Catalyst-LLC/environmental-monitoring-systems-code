{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EdgeEvent",
  "type": "object",
  "required": [
    "event_id",
    "component_id",
    "edge_rule_id",
    "event_type",
    "phenomenon_time",
    "result_time",
    "ingested_at",
    "quality_flag",
    "raw_context_retained",
    "delayed_record"
  ],
  "properties": {
    "event_id": {"type": "string"},
    "component_id": {"type": "string"},
    "edge_rule_id": {"type": "string"},
    "model_id": {"type": "string"},
    "model_version": {"type": "string"},
    "event_type": {"type": "string"},
    "observed_property": {"type": "string"},
    "value": {"type": ["number", "string", "boolean"]},
    "unit": {"type": "string"},
    "phenomenon_time": {"type": "string", "format": "date-time"},
    "result_time": {"type": "string", "format": "date-time"},
    "ingested_at": {"type": "string", "format": "date-time"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "quality_flag": {"type": "string"},
    "raw_context_retained": {"type": "boolean"},
    "delayed_record": {"type": "boolean"},
    "retained_context_uri": {"type": "string"},
    "notes": {"type": "string"}
  }
}
