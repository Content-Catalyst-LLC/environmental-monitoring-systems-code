{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NetworkObservation",
  "type": "object",
  "required": [
    "observation_id",
    "node_id",
    "network_id",
    "observed_property",
    "value",
    "unit",
    "phenomenon_time",
    "result_time",
    "ingested_at",
    "quality_flag",
    "calibration_status"
  ],
  "properties": {
    "observation_id": {"type": "string"},
    "node_id": {"type": "string"},
    "network_id": {"type": "string"},
    "site_id": {"type": "string"},
    "observed_property": {"type": "string"},
    "value": {"type": ["number", "string", "boolean"]},
    "unit": {"type": "string"},
    "phenomenon_time": {"type": "string", "format": "date-time"},
    "result_time": {"type": "string", "format": "date-time"},
    "ingested_at": {"type": "string", "format": "date-time"},
    "latitude": {"type": "number"},
    "longitude": {"type": "number"},
    "quality_flag": {"type": "string"},
    "calibration_status": {"type": "string"},
    "telemetry_status": {"type": "string"},
    "provenance": {"type": "string"}
  }
}
