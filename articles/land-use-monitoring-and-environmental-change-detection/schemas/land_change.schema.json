{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LandChangeRecord",
  "type": "object",
  "required": [
    "change_id",
    "product_id",
    "geography",
    "from_class",
    "to_class",
    "change_type",
    "change_year",
    "confidence",
    "persistence_score",
    "validated",
    "reporting_relevance"
  ],
  "properties": {
    "change_id": {"type": "string"},
    "product_id": {"type": "string"},
    "geography": {"type": "string"},
    "site_id": {"type": "string"},
    "from_class": {"type": "string"},
    "to_class": {"type": "string"},
    "change_type": {"type": "string"},
    "change_year": {"type": "integer"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "persistence_score": {"type": "number", "minimum": 0, "maximum": 1},
    "validated": {"type": "boolean"},
    "reporting_relevance": {"type": "string"},
    "notes": {"type": "string"}
  }
}
