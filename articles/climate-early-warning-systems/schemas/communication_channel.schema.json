    "program_id": {"type": "string"},
    "channel_type": {"type": "string"},
    "channel_name": {"type": "string"},
    "coverage_estimate": {"type": "number"},
    "language_access": {"type": "string"},
    "accessibility_support": {"type": "string"},
    "fallback_available": {"type": "boolean"},
    "status": {"type": "string"},
    "notes": {"type": "string"}
  }
}
